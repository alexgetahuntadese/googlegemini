NODE_ENV=development
PORT=4173
API_RATE_LIMIT_PER_MINUTE=120
BODY_LIMIT_BYTES=1000000
REQUEST_TIMEOUT_MS=30000
GITLAB_WEBHOOK_TOKEN=replace-with-a-random-shared-secret
ALLOW_RUNTIME_SETUP=true

# GitLab live read-only integration:
GITLAB_BASE_URL=https://gitlab.com
GITLAB_PROJECT_ID=12345678
GITLAB_TOKEN=glpat-replace-with-a-project-or-personal-access-token

# Gemini patch drafting:
GEMINI_MODEL=gemini-3-pro
GEMINI_API_KEY=replace-with-a-gemini-api-key
